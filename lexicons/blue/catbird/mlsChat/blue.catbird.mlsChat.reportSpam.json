{
  "lexicon": 1,
  "id": "blue.catbird.mlsChat.reportSpam",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Report an account as spam in an MLS conversation.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["convoId", "reportedDid"],
          "properties": {
            "convoId": { "type": "string", "description": "The conversation ID" },
            "reportedDid": { "type": "string", "format": "did", "description": "DID of the account being reported" },
            "reason": { "type": "string", "maxLength": 1000, "description": "Optional reason for the report" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["id", "createdAt"],
          "properties": {
            "id": { "type": "string" },
            "createdAt": { "type": "string", "format": "datetime" }
          }
        }
      },
      "errors": [
        { "name": "ConversationNotFound" },
        { "name": "NotAMember" },
        { "name": "AlreadyReported" }
      ]
    }
  }
}
