{
  "lexicon": 1,
  "id": "blue.catbird.mlsChat.removeDevice",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Remove a registered MLS device and clean up associated resources (key packages, conversation memberships, pending welcome messages).",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["deviceId"],
          "properties": {
            "deviceId": {
              "type": "string",
              "description": "The device ID to remove."
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["deleted"],
          "properties": {
            "deleted": {
              "type": "boolean",
              "description": "Whether the device was successfully deleted."
            },
            "keyPackagesDeleted": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of key packages that were removed."
            },
            "conversationsLeft": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of conversations the device was removed from."
            }
          }
        }
      },
      "errors": [
        {
          "name": "DeviceNotFound"
        }
      ]
    }
  }
}
